{
  "name": "@dispatch/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "SEE LICENSE IN README.md",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:sidecars": "bun build ../../packages/server/src/bin.ts --compile --outfile src-tauri/resources/dispatchd && bun build ../../packages/mcp/src/bin.ts --compile --outfile src-tauri/resources/dispatch-mcp && chmod +x src-tauri/resources/dispatchd src-tauri/resources/dispatch-mcp",
    "build:app": "bun run build && bun run build:sidecars",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "bun test",
    "tsc": "tsc -b --noEmit"
  },
  "dependencies": {
    "@dispatch/client": "workspace:*",
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@fontsource/ibm-plex-mono": "catalog:",
    "@fontsource/inter": "catalog:",
    "@pierre/diffs": "catalog:",
    "@pierre/trees": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-dialog": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "rehype-highlight": "catalog:",
    "remark-gfm": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@dispatch/core": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
