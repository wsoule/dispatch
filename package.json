{
  "name": "@dispatch/monorepo",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "commander": "13.1.0",
      "yaml": "2.9.0",
      "@types/bun": "1.3.12",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.1",
      "@typescript/native-preview": "7.0.0-dev.20260128.1",
      "@vitejs/plugin-react": "5.0.4",
      "husky": "^9.1.7",
      "lint-staged": "16.2.7",
      "oxfmt": "0.27.0",
      "oxlint": "1.42.0",
      "oxlint-tsgolint": "0.11.3",
      "postcss-html": "1.7.0",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "stylelint": "16.25.0",
      "stylelint-config-standard": "39.0.1",
      "tsdown": "0.15.11",
      "typescript": "5.9.2",
      "vite": "7.1.9"
    }
  },
  "type": "module",
  "scripts": {
    "ws": "bun --silent scripts/ws.ts",
    "tsc": "bun run ws \"*\" tsc --sequential",
    "test": "bun run ws \"packages/*\" test --sequential",
    "build": "bun run ws \"packages/*\" build --sequential",
    "clean": "rm -rf packages/*/dist apps/*/dist apps/*/.next packages/*/tsconfig.tsbuildinfo apps/*/tsconfig.tsbuildinfo",
    "clean:all": "bun run clean && rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "lint": "oxlint --type-aware --tsconfig tsconfig.oxlint.json .",
    "lint:fix": "oxlint --type-aware --tsconfig tsconfig.oxlint.json --fix .",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:css:fix": "stylelint \"**/*.css\" --allow-empty-input --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "postcss-html": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "typescript": "catalog:"
  },
  "overrides": {
    "typescript": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxfmt --write",
      "oxlint --type-aware --tsconfig tsconfig.oxlint.json --fix"
    ],
    "**/*.{css,pcss,postcss}": [
      "stylelint --fix"
    ]
  }
}
